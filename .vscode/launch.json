{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C++ Debug (Linux)",
      "type": "cppdbg",
      "request": "launch",
      // 路径指向编译出的二进制文件，没有 .exe
      "program": "${fileDirname}/${fileBasenameNoExtension}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "为 gdb 启用整齐打印",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      // 调试前先执行上面定义的编译任务
      "preLaunchTask": "C/C++: g++ build active file",
      "miDebuggerPath": "/usr/bin/gdb"
    }
  ]
}